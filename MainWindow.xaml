<Window x:Class="QuanLyPhongTroWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyPhongTroWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="900">
    <Grid Background="White">
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#1B1F3B"></Setter>
                <Setter Property="Foreground" Value="Beige"></Setter>
                <Setter Property="FontFamily" Value="Candara"></Setter>
                <Setter Property="FontSize" Value="17"></Setter>
                <Setter Property="Width" Value="200"></Setter>
                <Setter Property="BorderBrush" Value="White"></Setter>
                <Setter Property="BorderThickness" Value="1,0.5,0.5,0.5"></Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="437*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Background="#1B1F3B">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Foreground="White"
                    FontFamily="Segoe UI" FontWeight="Bold" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"> 
             QUẢN LÝ <LineBreak></LineBreak>PHÒNG TRỌ
            </TextBlock>
            <StackPanel Background="#1B1F3B" Width="200" Grid.Row="1">
                <TextBlock Text="MAIN MENU"
        Foreground="#80FFFFFF"
        FontSize="12"
        FontWeight="SemiBold"
        Margin="20,15,0,5"
        Opacity="0.7"
        TextAlignment="Left"/>
                <Button Content="Phòng"
         Click="BtnPhong_Click"/>
                <Button Content="Khách thuê"
         Click="BtnKhach_Click"/>
                <Button Content="Hợp đồng"
           Click="BtnHopDong_Click"  />
                <Button Content="Chỉ số điện nước"
           Click="BtnChiSoDN_Click"  />
                <Button Content="Hóa đơn"
           Click="BtnHoaDon_Click"  />

            </StackPanel>
            <StackPanel Grid.Row="2">
                <TextBlock Text="BÁO CÁO"
         Foreground="#80FFFFFF"
         FontSize="12"
         FontWeight="SemiBold"
         Margin="20,15,0,5"
         Opacity="0.7"
         TextAlignment="Left"/>
                <Button Content="Thống kê "
         Click="BtnTKe_Click"/>
            </StackPanel>
            <Grid Grid.Column="1" Visibility="Collapsed">

            </Grid>

        </Grid>
        <!--=====================================<DataGrid  CHI SO DIEN NUOC==============================-->
        <Grid x:Name="GridChiSo"   Grid.Column="1" Visibility="Collapsed" Grid.ColumnSpan="2">
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="Candara"></Setter>
                    <Setter Property="FontSize" Value="15"></Setter>
                    <Setter Property="FontWeight" Value="Regular"></Setter>
                    <Setter Property="Margin" Value="15,5,0,0"></Setter>
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="15,0,0,0"></Setter>
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="100"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBlock Text="Chọn phòng"  ></TextBlock>
                    <ComboBox Width="200" Height="40" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Black" Margin="15,0,0,5">

                    </ComboBox>

                </Grid>
                <Grid Grid.Column="1">
                    <TextBlock Text="Chỉ số điện"  ></TextBlock>
                    <TextBox Width="200" Height="40"  HorizontalAlignment="Left" Background="Transparent" BorderBrush="Black"></TextBox>
                </Grid>
                <Grid Grid.Column="2">
                    <TextBlock Text="Chỉ số nước"></TextBlock>
                    <TextBox Width="200" Height="40"  HorizontalAlignment="Left" Background="Transparent" BorderBrush="Black"></TextBox>
                    <Button x:Name="BtnLuuChiSo" Content="Lưu chỉ số" Width="100" Height="25" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,0" Background="MediumSeaGreen" Click="BtnLuuChiSo_Click"></Button>
                </Grid>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="23*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Lịch sử ghi nhận" Margin="0,5,0,0" Background="DarkSlateGray" Foreground="#FFF5F5DC" Grid.ColumnSpan="2"></TextBlock>
                <DataGrid
       ItemsSource="{Binding LichSuChiSo}"
       AutoGenerateColumns="False"
       IsReadOnly="True" Margin="0,30,0,0" FontFamily="Candara" FontWeight="DemiBold" FontSize="15" Grid.ColumnSpan="2">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày nhập" Binding="{Binding Ngay}" Width="150" />
                        <DataGridTextColumn Header="Chỉ số điện" Binding="{Binding Dien}" Width="150" />
                        <DataGridTextColumn Header="Chỉ số nước" Binding="{Binding Nuoc}" Width="150" />
                        <DataGridTextColumn Header="Người nhập" Binding="{Binding NguoiNhap}" Width="150" />
                    </DataGrid.Columns>

                </DataGrid>

            </Grid>
        </Grid>
        <!--đây là cột lớn bên tay phải tách ra làm 2 hàng-->
        <!--=========<DataGrid Khách thuê==============================--> 
        

        <Grid x:Name="GridKhachThue"  Grid.Column="1" Visibility="Visible" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="545*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
            </Grid>
<!--========================================<TabControl thứ nhất===================================================-->

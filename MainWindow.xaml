            <TabControl Grid.Row="1">
                <TabItem Header="Khách thuê">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" 
                        CornerRadius="15"
                        Background="#F0F0F0"
                        Padding="10,0"
                        Width="280"
                        Height="35"
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Center" 
                        Margin="20,0,0,0">
                                <TextBox x:Name="txtSearch"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="Black"
                             VerticalContentAlignment="Center"
                             Tag="Tìm kiếm khách thuê..."
                             TextChanged="txtSearch_TextChanged"/>
                            </Border>

                            <Border Grid.Column="1" 
                        CornerRadius="10" 
                        Background="LightSeaGreen"
                        Width="180" 
                        Height="35" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" 
                        Margin="0,0,20,0">
                                <Button x:Name="btthemKT" 
                            Background="Transparent" 
                            Foreground="White"
                            FontFamily="Segoe UI"
                            FontWeight="DemiBold"
                            Content="+ Thêm khách thuê"
                            BorderThickness="0" 
                            Cursor="Hand"/>
                            </Border>
                        </Grid>

                        <DataGrid x:Name="dgKhachThue" 
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Margin="20,10,20,20"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="40" 
                      SelectionChanged="dgKhachThue_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Background" Value="LightSeaGreen"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Phòng" Binding="{Binding Room}" Width="80" />
                                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*" />
                                <DataGridTextColumn Header="Số Điện Thoại" Binding="{Binding Phone}" Width="150" />
                                <DataGridTextColumn Header="Ngày Vào Ở" Binding="{Binding MoveInDate}" Width="150" />
                                <DataGridTemplateColumn Header="Thao tác" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Sửa" Margin="5" Click="Edit_Click"/>
                                                <Button Content="Xóa" Margin="5" Click="Delete_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
        <!--==============================================DataGrid THONG KE==================================================================-->
        <Grid x:Name="GridThongKe" Grid.Column="1" Background="#EEF1F5" Visibility="Collapsed" Grid.ColumnSpan="2">

            <Grid.Resources>

                <!-- CARD STYLE -->
                <Style x:Key="CardStyle" TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="CornerRadius" Value="14"/>
                    <Setter Property="Padding" Value="16"/>
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15"
                                   ShadowDepth="2"
                                   Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>

                    <!-- hover -->
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>

            </Grid.Resources>


            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="160"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <TextBlock Text="📊 DASHBOARD QUẢN LÝ NHÀ TRỌ"
            FontSize="26"
            FontWeight="Bold"
            Margin="20,20,0,0"/>


            <!-- ================= KPI CARDS ================= -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="20">

                <!-- DOANH THU -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>

                        <TextBlock Text="💰 Doanh thu"
                        Foreground="Gray"/>

                        <TextBlock Text="{Binding DoanhThuThangNay}"
                        FontSize="24"
                        FontWeight="Bold"
                        Margin="0,5"/>

                        <ProgressBar Value="{Binding DoanhThuPercent}"
                          Height="10"
                          Maximum="100"
                          Foreground="#4CAF50"/>

                        <TextBlock Text="{Binding DoanhThuTangGiamText}"
                        Foreground="Green"/>
                    </StackPanel>
                </Border>


                <!-- ĐIỆN -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="⚡ Tiền điện" Foreground="Gray"/>
                        <TextBlock Text="{Binding TienDien}"
                        FontSize="24"
                        FontWeight="Bold"
                        Margin="0,5"/>

                        <ProgressBar Value="{Binding DienPercent}"
                          Height="10"
                          Maximum="100"
                          Foreground="#FF9800"/>
                    </StackPanel>
                </Border>


                <!-- NƯỚC -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="💧 Tiền nước" Foreground="Gray"/>
                        <TextBlock Text="{Binding TienNuoc}"
                        FontSize="24"
                        FontWeight="Bold"
                        Margin="0,5"/>

                        <ProgressBar Value="{Binding NuocPercent}"
                          Height="10"
                          Maximum="100"
                          Foreground="#2196F3"/>
                    </StackPanel>
                </Border>


                <!-- LẤP ĐẦY -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🏠 Lấp đầy" Foreground="Gray"/>
                        <TextBlock Text="{Binding TiLeLapDay}"
                        FontSize="24"
                        FontWeight="Bold"
                        Margin="0,5"/>

                        <ProgressBar Value="{Binding LapDayPercent}"
                          Height="10"
                          Maximum="100"
                          Foreground="#9C27B0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>


            <!-- ================= MINI BAR CHART GIẢ ================= -->

            <Border Grid.Row="2"
         Style="{StaticResource CardStyle}"
         Margin="20">

                <StackPanel>

                    <TextBlock Text="📈 Doanh thu 6 tháng"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="10"/>

                    <ItemsControl ItemsSource="{Binding MiniChartData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                 VerticalAlignment="Bottom"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8"
                                 VerticalAlignment="Bottom">

                                    <!-- Cột -->
                                    <Rectangle Width="28"
                                    Height="{Binding Height}"
                                    Fill="#4CAF50"
                                    RadiusX="6"
                                    RadiusY="6"/>

                                    <TextBlock Text="{Binding Label}"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>
